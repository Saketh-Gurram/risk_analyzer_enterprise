# AWS Configuration
AWS_REGION=us-east-1

# S3 Configuration
S3_BUCKET_NAME=retail-risk-intelligence-bucket

# DynamoDB Configuration
DYNAMODB_TABLE_NAME=retail-risk-intelligence

# SageMaker Configuration
SAGEMAKER_ENDPOINT_NAME=risk-detection-endpoint

# Amazon Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Risk Thresholds (Optional - defaults provided)
RISK_THRESHOLD_LOW_MEDIUM=0.15
RISK_THRESHOLD_MEDIUM_HIGH=0.3

# Simulation Configuration (Optional)
DEFAULT_SIMULATION_TIME_HORIZON_DAYS=90
DEFAULT_MONTE_CARLO_ITERATIONS=1000
